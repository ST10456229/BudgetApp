<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Budget_App" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="android:windowBackground">@color/dark_gray_bg</item>
        <item name="colorSurface">@color/dark_card_bg</item>
        <item name="android:textColorPrimary">@color/dark_text_primary</item>
        <item name="android:textColorSecondary">@color/dark_text_secondary</item>

        <!-- Surface variants for dark mode -->
        <item name="colorSurfaceVariant">#2C2C2C</item>
        <item name="strokeColor">#333333</item>
        <item name="colorOnSurface">@color/dark_text_primary</item>
    </style>
</resources>