<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Budget_App" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Light Mode Colors -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/light_gray_bg</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/gray_text</item>

        <!-- Surface variants -->
        <item name="colorSurfaceVariant">#F1F4F9</item>
        <item name="strokeColor">@color/divider_color</item>

        <!-- Material Components attributes -->
        <item name="cardBackgroundColor">?attr/colorSurface</item>
    </style>

    <style name="Theme.Budget_App" parent="Base.Theme.Budget_App" />
</resources>